# MiMo V2.5 Vision API
# 喺 platform.xiaomimimo.com 攞 API key
# 留空 = mock 模式（demo 友好，零 cost）
VITE_MIMO_API_KEY=

# OpenAI-compatible base URL（包尾 /v1）
# Default: Singapore token plan endpoint
VITE_MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Vision OCR 必須用 mimo-v2-omni（multimodal）
# v2.5-pro / v2.5 / v2-pro 唔支援 image input，會回 404
VITE_MIMO_MODEL=mimo-v2-omni
